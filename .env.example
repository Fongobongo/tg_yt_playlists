# Telegram Bot token from BotFather
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Database connection URL.
# For Supabase IPv4 pooler: postgresql://postgres.[YOUR-PROJECT-REF]:[URL_ENCODED_PASSWORD]@aws-1-eu-west-1.pooler.supabase.com:5432/postgres?sslmode=require
# For local PostgreSQL: postgresql://postgres:postgres@localhost:5432/tg_yt
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/tg_yt

# Public HTTPS base URL for Telegram webhooks.
WEBHOOK_BASE_URL=https://your-koyeb-app.koyeb.app

# Shared secret sent by Telegram in X-Telegram-Bot-Api-Secret-Token.
WEBHOOK_SECRET=change_me_to_a_long_random_secret

# Path part of the webhook endpoint.
WEBHOOK_PATH=/telegram/webhook

# HTTP port. Koyeb injects PORT automatically.
PORT=8080

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
