# Telegram Bot token from BotFather
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Database connection URL.
# For Supabase: postgresql://postgres:[YOUR-PASSWORD]@[YOUR-PROJECT-REF].supabase.co:5432/postgres
# For local PostgreSQL: postgresql://postgres:postgres@localhost:5432/tg_yt
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/tg_yt

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO